[Unit]
Description=JARVIS Web Interface
Documentation=https://github.com/ulrich/jarvis
After=jarvis-brain.service
Requires=jarvis-brain.service

[Service]
Type=simple
User=jarvis
Group=jarvis
WorkingDirectory=/opt/jarvis
EnvironmentFile=/opt/jarvis/.env.os
ExecStart=/opt/jarvis/.venv/bin/python -m shells.web.server
Restart=always
RestartSec=3
TimeoutStartSec=30

# Hardening
ProtectSystem=strict
ReadWritePaths=/var/lib/jarvis /opt/jarvis
PrivateTmp=true

[Install]
WantedBy=jarvis.target
