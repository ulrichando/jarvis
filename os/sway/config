# ╔══════════════════════════════════════════════════════════════╗
# ║  JARVIS OS — Sway Window Manager Configuration             ║
# ╚══════════════════════════════════════════════════════════════╝

set $mod Mod4

# ── Output ────────────────────────────────────────────────────
output * bg /opt/jarvis/os/assets/wallpaper.png fill
output * scale 1

# ── Appearance ────────────────────────────────────────────────
default_border none
default_floating_border pixel 2
gaps inner 0
gaps outer 0
font pango:Fira Code 11

# Window colors (JARVIS blue theme)
client.focused          #2a5a8a #0a0a1a #4a8aba #2a5a8a #2a5a8a
client.focused_inactive #1a1a2e #0a0a1a #666666 #1a1a2e #1a1a2e
client.unfocused        #1a1a2e #0a0a1a #444444 #1a1a2e #1a1a2e

# ── Input ─────────────────────────────────────────────────────
input * {
    xkb_layout us
    repeat_delay 300
    repeat_rate 50
}

# ── Autostart ─────────────────────────────────────────────────

# Notification daemon
exec mako

# Wait for web server, then launch JARVIS UI
exec_always {
    bash -c '
        for i in $(seq 1 30); do
            curl -s http://localhost:8765 > /dev/null 2>&1 && break
            sleep 1
        done
        swaymsg "exec chromium \
            --kiosk \
            --no-first-run \
            --disable-translate \
            --disable-infobars \
            --disable-suggestions-service \
            --no-default-browser-check \
            --autoplay-policy=no-user-gesture-required \
            --use-fake-ui-for-media-stream \
            --enable-features=UseOzonePlatform \
            --ozone-platform=wayland \
            http://localhost:8765"
    '
}

# ── JARVIS CLI Mode ───────────────────────────────────────────

# Launch JARVIS CLI (the Claude Code-inspired agent shell)
bindsym $mod+j exec foot -T "JARVIS CLI" -e /opt/jarvis/.venv/bin/python -m shells.cli.jarvis_cli

# Launch JARVIS Terminal (interactive REPL with /learn, /recall, etc.)
bindsym $mod+t exec foot -T "JARVIS Terminal" -e /opt/jarvis/.venv/bin/python -m shells.terminal.cli

# Assign workspaces: 1=Web UI, 2=CLI, 3=Terminal, 4=System
assign [title="JARVIS CLI"] workspace 2
assign [title="JARVIS Terminal"] workspace 3

# ── Keybindings ───────────────────────────────────────────────

# System terminal
bindsym $mod+Return exec foot

# Kill focused window
bindsym $mod+q kill

# Fullscreen
bindsym $mod+f fullscreen toggle

# Toggle floating
bindsym $mod+Shift+space floating toggle

# Quick workspace switching
# Mod+1 = Web UI (arc reactor)
# Mod+2 = JARVIS CLI (agent mode)
# Mod+3 = JARVIS Terminal (REPL)
# Mod+4 = System

# Move focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move windows
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4

# Screenshot
bindsym Print exec grim - | wl-copy
bindsym $mod+Print exec grim -g "$(slurp)" - | wl-copy

# Reload Sway config
bindsym $mod+Shift+c reload

# Exit JARVIS OS
bindsym $mod+Shift+e exec swaynag -t warning \
    -m 'Shutdown JARVIS OS?' \
    -B 'Shutdown' 'systemctl poweroff' \
    -B 'Reboot' 'systemctl reboot' \
    -B 'Logout' 'swaymsg exit'

# Lock screen
bindsym $mod+Escape exec swaylock -f -c 0a0a1a \
    --indicator-color 2a5a8a \
    --ring-color 1a3a5a \
    --key-hl-color 4a8aba \
    --text-color 4a8aba

# ── Status Bar ────────────────────────────────────────────────
bar {
    swaybar_command waybar
}

# ── Idle ──────────────────────────────────────────────────────
exec swayidle -w \
    timeout 600 'swaylock -f -c 0a0a1a' \
    timeout 900 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"'
