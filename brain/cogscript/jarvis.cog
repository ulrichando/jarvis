# ============================================================
# JARVIS Brain — Autonomous CogScript Architecture
#
# No LLM. Learns by perceiving, searching, conversing.
#
# RECEIVE -> SEE -> HEAR -> THINK -> RESPOND -> LEARN
# ============================================================

brain Jarvis:

    # ── SENSES ──
    region eyes = Perception("camera")
    region ears = Perception("microphone")

    # ── MEMORY ──
    region focus = WorkingMemory(capacity=12)
    region knowledge = LongTermMemory(backend="numpy")
    region history = EpisodicMemory()

    # ── MIND ──
    region mind = ReasoningEngine(mode="hybrid")
    region curiosity = ActiveLearning(strategy="entropy_sampling")

    # ── GROWTH ──
    region dna = SelfEvolution(strategy="genetic")
    region gym = PracticeLoop(algorithm="ppo")

    # ── MODULAR PATHWAYS ──
    include "perception.cog"
    include "learning.cog"
    include "evolution.cog"

    # ============================================================
    # RECEIVE: Clear working memory and store the user's input
    #
    # The variable 'user_input' is injected into the environment
    # by the runner before execution. This pathway bridges it
    # into working memory where think/respond/absorb can find it.
    # ============================================================
    pathway receive:
        forget focus, "user_input"
        forget focus, "answer"
        forget focus, "response"
        forget focus, "scene"
        forget focus, "heard"
        forget focus, "mood"
        remember focus, user_input, key="user_input"

    # ============================================================
    # THINK: Reason over what Jarvis KNOWS — not what he guesses
    #
    # Combines the user's input with what Jarvis just saw and
    # heard (from the see/hear pathways). Searches long-term
    # memory for relevant facts, then runs forward-chaining
    # inference on the reasoning KB.
    # ============================================================
    pathway think:
        let input_data = recall focus, query="user_input"
        let relevant = recall knowledge, query=input_data, top_k=10
        let past = recall history, limit=10

        # Include current perception context if available
        let scene = recall focus, query="scene"
        let heard = recall focus, query="heard"

        # Store LTM results for the response pathway
        remember focus, relevant, key="ltm_results"

        # Run structured reasoning with full context
        let answer = reason mind:
            given relevant, past, scene, heard
            infer input_data

        remember focus, answer, key="answer"
        episode history, action="thought", data=answer

    # ============================================================
    # RESPOND: Build a response from what the mind concluded
    # ============================================================
    pathway respond:
        let answer = recall focus, query="answer"
        remember focus, answer, key="response"
        episode history, action="responded", data=answer

    # ============================================================
    # MAIN CYCLE
    #
    #   1. Receive user input into working memory
    #   2. See what's in front of the camera
    #   3. Listen for speech from the microphone
    #   4. Think about all of it together
    #   5. Build a response
    #   6. Learn from the exchange
    # ============================================================
    on start:
        spawn receive
        spawn see
        spawn hear
        spawn think
        spawn respond
        spawn absorb
