#!/usr/bin/env bash
# jarvis-mode-resume — restore the last-active conversation mode on
# user-session start. Wired in via ~/.config/systemd/user/jarvis-mode-
# resume.service (oneshot, ordered After=jarvis-voice-client.service).
#
# Reads $HOME/.jarvis/active-mode (one of: jarvis | gemini | openai),
# default "jarvis", and invokes the matching jarvis-mode subcommand
# if and only if the mode isn't already correct.
#
# Idempotent — running it twice is safe; the second invocation finds
# the desired mode already active and exits clean.

set -euo pipefail

STATE_FILE="$HOME/.jarvis/active-mode"
BIN_DIR="$(dirname "$(readlink -f "$0")")"
JARVIS_MODE="${BIN_DIR}/jarvis-mode"

if [[ ! -x "$JARVIS_MODE" ]]; then
    echo "[mode-resume] jarvis-mode not executable at $JARVIS_MODE" >&2
    exit 2
fi

# Default to "jarvis" when no state file or it's empty.
desired="jarvis"
if [[ -f "$STATE_FILE" ]]; then
    desired="$(head -n1 "$STATE_FILE" | tr -d '[:space:]')"
fi
[[ -z "$desired" ]] && desired="jarvis"

case "$desired" in
    jarvis|gemini|openai) ;;
    *)
        echo "[mode-resume] unrecognized desired mode '$desired' — defaulting to jarvis" >&2
        desired="jarvis"
        ;;
esac

# Wait briefly for voice-client to be reachable so set_jarvis_mute
# inside jarvis-mode actually lands. Caps at ~15s; falls through
# either way (the mode switch itself doesn't require voice-client).
for _ in {1..15}; do
    if curl --silent --fail --max-time 1 \
            "http://127.0.0.1:${JARVIS_VOICE_CLIENT_PORT:-8767}/status" \
            >/dev/null 2>&1; then
        break
    fi
    sleep 1
done

# Idempotency check — if jarvis-mode reports the desired mode is
# already active, do nothing (avoid double mute/unmute cycles).
# Wrap in timeout so a hung jarvis-mode doesn't stall the unit past
# its TimeoutStartSec.
# `|| true` is load-bearing: under `set -euo pipefail`, if `jarvis-mode status`
# hangs at cold boot and `timeout 10` fires, the pipeline returns 124 and the
# bare command substitution would KILL the script with 124 — landing the unit in
# 'failed' (the exact "exit 124 for days" bug the line-68 guard below was meant
# to fix, but on the wrong line). Tolerate it: a timed-out probe just means
# current="" (unknown), and we fall through to the best-effort restore.
current="$(timeout 10 "$JARVIS_MODE" status 2>/dev/null | head -1 | sed -nE 's/^mode: ([a-z]+).*/\1/p' || true)"
if [[ "$current" == "$desired" ]]; then
    echo "[mode-resume] already in mode '$desired' — no-op"
    exit 0
fi

echo "[mode-resume] restoring mode → $desired (was: ${current:-unknown})"
# Best-effort: at login the voice stack may still be starting and
# jarvis-mode can blow its budget (live 2026-06-09: exit 124 left the
# unit 'failed' for days). A missed resume is cosmetic — the user can
# pick a mode from the tray — so warn and exit 0 instead of failing
# the unit.
rc=0
# 30s (was 50): the wait-loop (≤15s) + status probe (≤10s) + this must stay
# under the unit's TimeoutStartSec=60s, or systemd SIGTERMs the script and the
# unit fails anyway. 15+10+30=55s leaves margin. A cut-off switch is cosmetic.
timeout 30 "$JARVIS_MODE" "$desired" || rc=$?
if [[ $rc -ne 0 ]]; then
    echo "[mode-resume] jarvis-mode '$desired' did not complete (rc=$rc) — leaving mode as-is" >&2
fi
exit 0
