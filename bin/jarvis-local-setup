#!/usr/bin/env bash
# jarvis-local-setup — one-command local-LLM setup for a new box.
#
# Detects this machine's GPU VRAM + RAM, asks the hwfit picker
# (src/voice-agent/providers/local_model_picker.py) for the best-fitting
# tool-capable Ollama model, and `ollama pull`s it. Then you just set
# JARVIS_LOCAL_LLM_MODEL=auto (or the printed tag) in src/voice-agent/.env
# and restart the agent.
#
# Usage:
#   bin/jarvis-local-setup            # detect → recommend → prompt → pull
#   bin/jarvis-local-setup -y         # pull without prompting
#   bin/jarvis-local-setup --dry-run  # show the pick, pull nothing
#   bin/jarvis-local-setup --model X  # pull a specific tag instead of the pick
#   bin/jarvis-local-setup -h
#
# The picker is stdlib-only, so this works even before `pip install` —
# handy on a freshly-cloned box.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VOICE_AGENT_DIR="$REPO_ROOT/src/voice-agent"
PYTHON="$VOICE_AGENT_DIR/.venv/bin/python"
[ -x "$PYTHON" ] || PYTHON="$(command -v python3 || true)"

ASSUME_YES=0
DRY_RUN=0
FORCE_MODEL=""
while [ $# -gt 0 ]; do
  case "$1" in
    -y|--yes) ASSUME_YES=1 ;;
    -n|--dry-run) DRY_RUN=1 ;;
    --model) shift; FORCE_MODEL="${1:-}" ;;
    -h|--help) sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "unknown arg: $1 (try -h)" >&2; exit 2 ;;
  esac
  shift
done

if ! command -v ollama >/dev/null 2>&1; then
  echo "✗ ollama is not installed." >&2
  echo "  Install it first:  curl -fsSL https://ollama.com/install.sh | sh" >&2
  exit 1
fi
if [ -z "$PYTHON" ]; then
  echo "✗ no python found (looked for $VOICE_AGENT_DIR/.venv/bin/python and python3)." >&2
  exit 1
fi

if [ -n "$FORCE_MODEL" ]; then
  TAG="$FORCE_MODEL"; PULLED="no"
  echo ""
  echo "  Model (forced):  $TAG"
  echo ""
else
  # Human summary → stderr (streams to terminal); machine line "<tag> <yes|no>" → stdout.
  PICK="$(
    cd "$VOICE_AGENT_DIR" && PYTHONPATH=. "$PYTHON" - <<'PY'
import sys
from providers.local_model_picker import recommend, _MODELS
p = recommend()
size = {m[0]: m[2] for m in _MODELS}.get(p.tag, p.footprint_gb)
e = sys.stderr
print("", file=e)
print("  Hardware:   VRAM=%s GB   RAM=%s GB" % (p.vram_gb, p.ram_gb), file=e)
print("  Best fit:   %s   (%s)" % (p.tag, p.run_mode), file=e)
print("  Detail:     %s" % p.note, file=e)
print("  ~download:  %.0f GB (Q4_K_M)" % size, file=e)
print("  Pulled?:    %s" % ("yes — ready to use" if p.available else "no — will pull"), file=e)
print("", file=e)
print("%s %s" % (p.tag, "yes" if p.available else "no"))
PY
  )"
  TAG="${PICK%% *}"
  PULLED="${PICK##* }"
fi

if [ "$PULLED" = "yes" ]; then
  echo "✓ $TAG is already pulled — you're set."
  echo "  Set JARVIS_LOCAL_LLM_MODEL=auto (or $TAG) in src/voice-agent/.env and restart."
  exit 0
fi

if [ "$DRY_RUN" = "1" ]; then
  echo "(dry-run) would run:  ollama pull $TAG"
  exit 0
fi

if [ "$ASSUME_YES" != "1" ]; then
  printf "Pull %s now? [Y/n] " "$TAG"
  read -r ans || ans=""
  case "$ans" in [nN]*) echo "skipped — nothing pulled."; exit 0 ;; esac
fi

echo ">>> ollama pull $TAG"
ollama pull "$TAG"
echo ""
echo "✓ $TAG pulled. Next:"
echo "    1) src/voice-agent/.env:  JARVIS_LOCAL_LLM_ENABLED=1  +  JARVIS_LOCAL_LLM_MODEL=auto"
echo "    2) restart:  systemctl --user restart jarvis-voice-agent.service"
