#!/usr/bin/env bash
# Global launcher for Jarvis CLI
# Usage: jarvis [args...]
# Install: ln -sf /home/ulrich/Documents/Projects/jarvis/bin/jarvis ~/.local/bin/jarvis

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
JARVIS_ROOT="$SCRIPT_DIR/../src/cli"
SCRIPTS="$JARVIS_ROOT/scripts"

exec bash "$SCRIPTS/start.sh" "$@"
