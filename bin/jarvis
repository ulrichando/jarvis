=======

JARVIS_ROOT="/home/ulrich/Documents/Projects/jarvis/src/cli"
SCRIPTS="$JARVIS_ROOT/scripts"

# `clear` only makes sense when stdout is a TTY (interactive launch). In
# --print / dispatch_agent subprocess contexts stdout is a pipe and clear
# exits 1 (esp. when TERM is unset), tripping `set -e` and killing the
# launcher before the agent loop ever starts.
[ -t 1 ] && clear || true
exec bash "$SCRIPTS/start.sh" "$@"
