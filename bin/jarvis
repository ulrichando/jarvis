#!/usr/bin/env bash
# Global launcher for Jarvis CLI
# Usage: jarvis [args...]
# Install: ln -sf /home/ulrich/Documents/Projects/jarvis/bin/jarvis ~/.local/bin/jarvis

set -euo pipefail

JARVIS_ROOT="/home/ulrich/Documents/Projects/jarvis/src/cli"
SCRIPTS="$JARVIS_ROOT/scripts"

# `clear` only makes sense when stdout is a TTY (interactive launch). In
# --print / dispatch_agent subprocess contexts stdout is a pipe and clear
# exits 1 (esp. when TERM is unset), tripping `set -e` and killing the
# launcher before the agent loop ever starts.
[ -t 1 ] && clear || true

# Interactive REPL (tty + no args) runs the COMPILED binary in DEFAULT
# permission mode: Shift+Tab cycles default → accept-edits → plan there
# (bypass supersedes the cycle). Source-run interactive works ONLY in
# bypass mode: deadlock #1 (bootstrap/state re-export cycle) is fixed,
# but a second order-dependent module deadlock remains on the non-bypass
# source boot branch (blank REPL; see cli-interactive-repl-deadlock
# memory). Until #2 is pinned, the bundle (no import order) is the
# interactive path; headless/subcommands stay on start.sh with bypass.
JARVIS_BIN="$JARVIS_ROOT/dist/jarvis-linux-x64"
if [ -t 1 ] && [ $# -eq 0 ] && [ -x "$JARVIS_BIN" ]; then
  source "$SCRIPTS/start-env.sh"
  source "$SCRIPTS/proxy-runtime.sh"
  jarvis_proxy_start "$JARVIS_ROOT" "$SCRIPTS/bunw.sh"
  # Launch in bypass ("autonomous") like the source path always did — AND
  # launching WITH bypass is what puts it in the Shift+Tab carousel
  # (getNextPermissionMode only offers bypassPermissions when
  # isBypassPermissionsModeAvailable, i.e. it was enabled at launch;
  # verified byte-identical with the claude-code donor). So this restores
  # autonomous-by-default while keeping default/auto/plan one Shift+Tab away.
  # start-env.sh always sets both vars (bypass default + sandbox settings).
  exec "$JARVIS_BIN" --permission-mode "$JARVIS_PERMISSION_MODE" --settings "$JARVIS_FLAG_SETTINGS"
fi
exec bash "$SCRIPTS/start.sh" "$@"
