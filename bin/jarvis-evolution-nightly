#!/usr/bin/env bash
# jarvis-evolution-nightly — run the bounded self-evolution cycle in AUTO mode.
#
# PROPOSAL-ONLY: runs detect -> self-assess -> priority queue -> build/retry and
# optional PR publish. It NEVER merges, deploys, or restarts anything — deploy
# only happens when you approve a proposal in /evolution. Driven by
# jarvis-evolution-nightly.timer on a periodic cadence; safe to run by hand.
#
# MANUAL by default: the Python entrypoint skips unless
# ~/.jarvis/auto-mods/.evolution-auto exists. AUTO mode still honors pause,
# recent-user-activity, deploy-in-flight, and the 5/day build budget.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VA="$REPO_ROOT/src/voice-agent"

cd "$VA" || exit 1
exec "$VA/.venv/bin/python" -m pipeline.automod.nightly
