#!/usr/bin/env bash
# Wrapper invoked by pipeline/automod/spawner.py for each admitted intent.
# Branches from master, spawns `bin/jarvis -p` with a rules prompt that
# constrains the CLI to src/voice-agent/ only, runs pytest, commits on
# green, and calls finalize.py to write the artifact JSON.
#
# Spec: docs/superpowers/specs/2026-05-24-jarvis-source-code-self-mod-design.md

set -euo pipefail

INTENT_FILE="$1"
ID="$(basename "$INTENT_FILE" .intent.txt)"
LOG="$HOME/.jarvis/auto-mods/$ID.log"
mkdir -p "$(dirname "$LOG")"

REPO_ROOT="/home/ulrich/Documents/Projects/jarvis"
cd "$REPO_ROOT"

BRANCH="automod/$ID"
{
  echo "[$(date -u +%FT%TZ)] [automod-impl] starting id=$ID"
  echo "[$(date -u +%FT%TZ)] [automod-impl] cwd=$REPO_ROOT branch=$BRANCH"

  git checkout master
  # Sync local master to origin/master BEFORE branching. Without this,
  # the proposal branch inherits whatever the local checkout had (which
  # may be tens of commits stale, especially after a fresh auto-merge
  # landed something to origin/master and the wrapper hasn't pulled).
  # Live failure 2026-05-28: local master was 39 commits behind origin
  # → subagent saw the OLD version of jarvis_agent.py → couldn't find
  # the target line the intent referenced → finalize wrote
  # status=failed → Stage 7 still tried to merge an empty branch.
  git fetch origin master --quiet
  git reset --hard origin/master --quiet
  git checkout -b "$BRANCH"

  INTENT_BODY="$(cat "$INTENT_FILE")"

  PROMPT="You are JARVIS auto-mod. A targeted code change has been
requested:

${INTENT_BODY}

HARD RULES (violating ANY means the spawner will reject your commit and delete this branch):

1. Edit ONLY files under src/voice-agent/.
2. Do NOT touch ANY of these paths:
   - src/voice-agent/sanitizers/
   - src/voice-agent/confab_detector.py
   - src/voice-agent/pipeline/automod/
   - src/voice-agent/pipeline/skill_review.py
   - src/voice-agent/prompts/soul.md
   - CLAUDE.md
   - .claude/rules/regression-prevention.md
   - MEMORY.md
   - USER.md
3. Do NOT delete tests or weaken assertions. You MAY add tests.
4. Do NOT add @pytest.mark.skip / @pytest.mark.skipif / @pytest.mark.xfail.
5. Before committing, run:
     cd src/voice-agent && .venv/bin/python -m pytest tests/ -q
6. If tests fail: DO NOT commit. Print the failure summary and stop.
7. If tests pass: git add only the files you edited (NEVER git add -A).
   Commit with a one-line Conventional Commit message describing the change.
8. DO NOT push.
9. Stop after ONE commit. Do NOT iterate.

The change must be focused and minimal. If you can't reduce the intent
to <=5 files and <=2000 diff lines, ABORT -- print why and exit without
committing."

  export JARVIS_AUTOMOD_NO_NETWORK=1
  timeout 600 "$REPO_ROOT/bin/jarvis" -p "$PROMPT" || true

  "$REPO_ROOT/src/voice-agent/.venv/bin/python" \
    "$REPO_ROOT/src/voice-agent/pipeline/automod/finalize.py" \
    "$ID" "$BRANCH"

  # ===== Stage 7: Auto-merge (Spec 2026-05-28) =====
  # Gate on finalize artifact status BEFORE checking AUTO_MERGE env.
  # finalize.py writes "status": "failed" on rejection (no commit landed,
  # blocklist hit, test failure) but exits 0 — set -e doesn't catch this.
  # Without this guard, Stage 7 fires on every failed proposal, tries to
  # merge an empty branch, and noises the log with "merge FAILED" lines.
  # Live failure 2026-05-28 smoke002: subagent ABORTed (stale-master bug,
  # fixed above), finalize wrote status=failed, Stage 7 still attempted
  # the merge.
  ARTIFACT_FILE="$HOME/.jarvis/auto-mods/$ID.json"
  if [ -f "$ARTIFACT_FILE" ]; then
      FINALIZE_STATUS=$(python3 -c "
import json, sys
try:
    print(json.load(open('$ARTIFACT_FILE')).get('status', 'unknown'))
except Exception:
    print('unparseable')
" 2>/dev/null)
      if [ "$FINALIZE_STATUS" != "pending" ]; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] finalize status=$FINALIZE_STATUS — skipping auto-merge (proposal not landable)"
          exit 0
      fi
  else
      echo "[$(date -u +%FT%TZ)] [automod-impl] no artifact file at $ARTIFACT_FILE — skipping auto-merge"
      exit 0
  fi

  # Fires only when JARVIS_AUTOMOD_AUTO_MERGE=1 AND all gates green.
  # set -e guarantees we only reach this point if both the subagent's
  # pytest run AND finalize.py exited cleanly above.
  # Saves refs/automod-rollback/<id> pointing at master pre-merge HEAD,
  # merges proposal branch, pushes master, restarts voice-agent.
  if [ "${JARVIS_AUTOMOD_AUTO_MERGE:-0}" = "1" ]; then
      echo "[$(date -u +%FT%TZ)] [automod-impl] AUTO_MERGE=1 — proceeding"

      # 7a. Save rollback ref BEFORE touching master.
      if ! git fetch origin master --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] origin fetch FAILED — aborting auto-merge"
          exit 0
      fi
      PRE_MERGE_SHA=$(git rev-parse origin/master)
      ROLLBACK_REF="refs/automod-rollback/$ID"
      git update-ref "$ROLLBACK_REF" "$PRE_MERGE_SHA"
      if ! git push origin "$ROLLBACK_REF:$ROLLBACK_REF" --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] rollback ref push FAILED — aborting auto-merge"
          exit 0
      fi

      # 7b. Merge proposal branch into master.
      if ! git checkout master --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] checkout master FAILED — aborting"
          exit 0
      fi
      # Sync local master to origin/master (already fetched in 7a — no failure path).
      git reset --hard origin/master --quiet
      if ! git merge --no-ff "$BRANCH" -m "automod: auto-merge $ID" --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] merge FAILED — aborting + reset"
          git merge --abort 2>/dev/null || true
          exit 0
      fi

      # 7c. Push master.
      if ! git push origin master --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] master push FAILED — reverting local merge"
          git reset --hard "$PRE_MERGE_SHA"
          exit 0
      fi

      MERGE_SHA=$(git rev-parse master)
      echo "[$(date -u +%FT%TZ)] [automod-impl] auto-merged: id=$ID merge_sha=$MERGE_SHA"

      # 7d. Stamp the artifact JSON with auto-merge metadata.
      "$REPO_ROOT/src/voice-agent/.venv/bin/python" \
          "$REPO_ROOT/src/voice-agent/pipeline/automod/finalize.py" \
          mark-auto-merged "$ID" \
          --rollback-ref "$ROLLBACK_REF" \
          --rollback-sha "$PRE_MERGE_SHA" \
          --merge-sha "$MERGE_SHA"

      # 7e. Restart the voice-agent so the new code is live.
      # Respect the existing "active session" guard from CLAUDE.md ops rule:
      # don't restart if the last turn was <60s ago.
      LAST_TURN_TS=$(sqlite3 ~/.local/share/jarvis/turn_telemetry.db \
          "SELECT strftime('%s', ts_utc) FROM turns ORDER BY id DESC LIMIT 1" 2>/dev/null || echo "0")
      NOW=$(date +%s)
      AGE=$((NOW - LAST_TURN_TS))
      if [ "$AGE" -gt 60 ]; then
          systemctl --user restart jarvis-voice-agent.service
          echo "[$(date -u +%FT%TZ)] [automod-impl] voice-agent restarted"
      else
          echo "[$(date -u +%FT%TZ)] [automod-impl] restart deferred (session active ${AGE}s ago); new code loads on next natural restart"
      fi
  fi
} >>"$LOG" 2>&1
