#!/usr/bin/env bash
# Wrapper invoked by pipeline/automod/spawner.py for each admitted intent.
# Branches from master, spawns `bin/jarvis -p` with a rules prompt that
# constrains the CLI to src/voice-agent/ only, runs pytest, commits on
# green, and calls finalize.py to write the artifact JSON.
#
# Spec: docs/superpowers/specs/2026-05-24-jarvis-source-code-self-mod-design.md

set -euo pipefail

INTENT_FILE="$1"
ID="$(basename "$INTENT_FILE" .intent.txt)"
JARVIS_HOME_DIR="${JARVIS_HOME:-$HOME/.jarvis}"
LOG="$JARVIS_HOME_DIR/auto-mods/$ID.log"
mkdir -p "$(dirname "$LOG")"

# Derive REPO_ROOT from this script's location (bin/..) so the wrapper
# works regardless of where the repo is checked out, not just one machine.
# The spawner may override it with a disposable git worktree so this wrapper
# never has to reset the live checkout.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
REPO_ROOT="${JARVIS_AUTOMOD_REPO_ROOT:-$DEFAULT_REPO_ROOT}"
TOOLING_ROOT="${JARVIS_AUTOMOD_TOOLING_ROOT:-$REPO_ROOT}"
cd "$REPO_ROOT"

BRANCH="automod/$ID"
{
  echo "[$(date -u +%FT%TZ)] [automod-impl] starting id=$ID"
  echo "[$(date -u +%FT%TZ)] [automod-impl] cwd=$REPO_ROOT branch=$BRANCH"

  # Branch from the CURRENT code (local master by default) without moving the
  # live checkout's master branch. In normal scheduler use REPO_ROOT is a
  # disposable detached worktree prepared by spawner.py (already based on this
  # ref). finalize._base_ref MUST match BASE_REF. origin/master is intentionally
  # stale on this box (local is ahead), so default to local master; override
  # with JARVIS_AUTOMOD_BASE_REF=origin/master to build against the remote.
  BASE_REF="${JARVIS_AUTOMOD_BASE_REF:-master}"
  case "$BASE_REF" in
    origin/*) [ "${JARVIS_AUTOMOD_SKIP_BASE_FETCH:-0}" != "1" ] && git fetch origin master --quiet ;;
  esac
  git checkout --detach "$BASE_REF" --quiet
  git checkout -b "$BRANCH" --quiet

  INTENT_BODY="$(cat "$INTENT_FILE")"

  # Pre-build RESEARCH (network-ALLOWED, read-only) — runs in a SEPARATE process
  # BEFORE the offline sandbox below, so it can ground the build in current
  # docs/best-practices without ever giving the build agent network. OFF by
  # default (JARVIS_AUTOMOD_RESEARCH=1). Best-effort; never blocks the build.
  RESEARCH_SECTION=""
  if [ "${JARVIS_AUTOMOD_RESEARCH:-0}" = "1" ]; then
    _RPY="$TOOLING_ROOT/src/voice-agent/.venv/bin/python"
    if [ -x "$_RPY" ]; then
      ( cd "$TOOLING_ROOT/src/voice-agent" \
          && JARVIS_AUTOMOD_RESEARCH=1 timeout 180 "$_RPY" -m pipeline.automod.research "$ID" "$INTENT_FILE" ) \
          >>"$LOG" 2>&1 || true
      _BRIEF="$JARVIS_HOME_DIR/auto-mods/$ID.research.md"
      if [ -s "$_BRIEF" ]; then
        RESEARCH_SECTION="$(printf 'RESEARCH BRIEF (grounding from online docs — consider it, but VERIFY against the actual code; never trust it blindly):\n%s\n\n' "$(cat "$_BRIEF")")"
        echo "[$(date -u +%FT%TZ)] [automod-impl] research brief attached ($(wc -c <"$_BRIEF") bytes)"
      fi
    fi
  fi

  PROMPT="You are JARVIS auto-mod. A targeted code change has been
requested:

${INTENT_BODY}

${RESEARCH_SECTION}HARD RULES (violating ANY means the spawner will reject your commit and delete this branch):

1. Edit ONLY files under src/voice-agent/.
2. Do NOT touch ANY of these paths:
   - src/voice-agent/sanitizers/
   - src/voice-agent/confab_detector.py
   - src/voice-agent/pipeline/automod/
   - src/voice-agent/pipeline/skill_review.py
   - src/voice-agent/prompts/soul.md
   - CLAUDE.md
   - .claude/rules/regression-prevention.md
   - MEMORY.md
   - USER.md
3. Do NOT delete tests or weaken assertions. You MAY add tests.
4. Do NOT add @pytest.mark.skip / @pytest.mark.skipif / @pytest.mark.xfail.
5. Before committing, run the test suite via the HERMETIC runner below (this
   worktree has no local .venv; the runner uses the tooling interpreter and
   strips the live service env so the suite matches a clean checkout — do NOT
   invoke pytest directly or it will report ~16 spurious env-dependent failures):
     cd src/voice-agent && ${TOOLING_ROOT}/bin/jarvis-automod-pytest tests/ -q
6. If tests fail: DO NOT commit. Print the failure summary and stop.
7. If tests pass: git add only the files you edited (NEVER git add -A).
   Commit with a one-line Conventional Commit message describing the change.
8. DO NOT push.
9. Stop after ONE commit. Do NOT iterate.

The change must be focused and minimal. If you can't reduce the intent
to <=5 files and <=2000 diff lines, ABORT -- print why and exit without
committing."

  # Evolution build-model picker: ~/.jarvis/auto-mods/build-model (set from the
  # /evolution UI) overrides the global cli-model for THIS build only. Empty or
  # absent → inherit the global model. start.sh honors JARVIS_AUTOMOD_BUILD_MODEL.
  _build_model_file="$HOME/.jarvis/auto-mods/build-model"
  if [ -r "$_build_model_file" ]; then
    _bm="$(tr -d '[:space:]' < "$_build_model_file")"
    [ -n "$_bm" ] && export JARVIS_AUTOMOD_BUILD_MODEL="$_bm"
  fi

  # Build network isolation. SECURITY: an autonomous, self-modifying coding agent
  # that RUNS what it writes can exfiltrate secrets or pull a malicious dep if it
  # has network — so the default is OFFLINE. Set JARVIS_AUTOMOD_BUILD_NETWORK=1 to
  # ALLOW the build agent to research online DURING the build (user directive
  # 2026-06-26): a deliberate opt-in that accepts that risk. Either way the
  # pre-build research stage above already grounds the build with online docs.
  if [ "${JARVIS_AUTOMOD_BUILD_NETWORK:-0}" = "1" ]; then
    echo "[$(date -u +%FT%TZ)] [automod-impl] BUILD NETWORK ENABLED — offline security boundary relaxed (research-during-build)"
  else
    export JARVIS_AUTOMOD_NO_NETWORK=1
  fi
  # 25 min for the coding agent itself; the spawner's SPAWN_TIMEOUT_S (30 min)
  # is the outer bound, leaving ~5 min for finalize (diff-gate + test re-run +
  # commit check) to run after. 10 min was too short → no_commit_landed.
  timeout "${JARVIS_AUTOMOD_BUILD_TIMEOUT_S:-1500}" "$TOOLING_ROOT/bin/jarvis" -p "$PROMPT" || true

  "$TOOLING_ROOT/src/voice-agent/.venv/bin/python" \
    "$REPO_ROOT/src/voice-agent/pipeline/automod/finalize.py" \
    "$ID" "$BRANCH"

  # ===== Stage 7: Auto-merge (Spec 2026-05-28) =====
  # Gate on finalize artifact status BEFORE checking AUTO_MERGE env.
  # finalize.py writes "status": "failed" on rejection (no commit landed,
  # blocklist hit, test failure) but exits 0 — set -e doesn't catch this.
  # Without this guard, Stage 7 fires on every failed proposal, tries to
  # merge an empty branch, and noises the log with "merge FAILED" lines.
  # Live failure 2026-05-28 smoke002: subagent ABORTed (stale-master bug,
  # fixed above), finalize wrote status=failed, Stage 7 still attempted
  # the merge.
  ARTIFACT_FILE="$JARVIS_HOME_DIR/auto-mods/$ID.json"
  if [ -f "$ARTIFACT_FILE" ]; then
      FINALIZE_STATUS=$(python3 -c "
import json, sys
try:
    print(json.load(open('$ARTIFACT_FILE')).get('status', 'unknown'))
except Exception:
    print('unparseable')
" 2>/dev/null)
      if [ "$FINALIZE_STATUS" != "pending" ]; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] finalize status=$FINALIZE_STATUS — skipping auto-merge (proposal not landable)"
          exit 0
      fi
  else
      echo "[$(date -u +%FT%TZ)] [automod-impl] no artifact file at $ARTIFACT_FILE — skipping auto-merge"
      exit 0
  fi

  # Fires only when JARVIS_AUTOMOD_AUTO_MERGE=1 AND all gates green.
  # set -e guarantees we only reach this point if both the subagent's
  # pytest run AND finalize.py exited cleanly above.
  # Saves refs/automod-rollback/<id> pointing at master pre-merge HEAD,
  # merges proposal branch, pushes master, restarts voice-agent.
  if [ "${JARVIS_AUTOMOD_AUTO_MERGE:-0}" = "1" ]; then
      if [ -n "${JARVIS_AUTOMOD_REPO_ROOT:-}" ]; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] AUTO_MERGE ignored in isolated worktree; use /evolution approval instead"
          exit 0
      fi

      echo "[$(date -u +%FT%TZ)] [automod-impl] AUTO_MERGE=1 — proceeding"

      # 7a. Save rollback ref BEFORE touching master.
      if ! git fetch origin master --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] origin fetch FAILED — aborting auto-merge"
          exit 0
      fi
      PRE_MERGE_SHA=$(git rev-parse origin/master)
      ROLLBACK_REF="refs/automod-rollback/$ID"
      git update-ref "$ROLLBACK_REF" "$PRE_MERGE_SHA"
      if ! git push origin "$ROLLBACK_REF:$ROLLBACK_REF" --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] rollback ref push FAILED — aborting auto-merge"
          exit 0
      fi

      # 7b. Merge proposal branch into master.
      if ! git checkout master --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] checkout master FAILED — aborting"
          exit 0
      fi
      # Sync local master to origin/master (already fetched in 7a — no failure path).
      git reset --hard origin/master --quiet
      if ! git merge --no-ff "$BRANCH" -m "automod: auto-merge $ID" --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] merge FAILED — aborting + reset"
          git merge --abort 2>/dev/null || true
          exit 0
      fi

      # 7c. Push master.
      if ! git push origin master --quiet; then
          echo "[$(date -u +%FT%TZ)] [automod-impl] master push FAILED — reverting local merge"
          git reset --hard "$PRE_MERGE_SHA"
          exit 0
      fi

      MERGE_SHA=$(git rev-parse master)
      echo "[$(date -u +%FT%TZ)] [automod-impl] auto-merged: id=$ID merge_sha=$MERGE_SHA"

      # 7d. Stamp the artifact JSON with auto-merge metadata.
      "$TOOLING_ROOT/src/voice-agent/.venv/bin/python" \
          "$REPO_ROOT/src/voice-agent/pipeline/automod/finalize.py" \
          mark-auto-merged "$ID" \
          --rollback-ref "$ROLLBACK_REF" \
          --rollback-sha "$PRE_MERGE_SHA" \
          --merge-sha "$MERGE_SHA"

      # 7e. Restart the voice-agent so the new code is live.
      # Respect the existing "active session" guard from CLAUDE.md ops rule:
      # don't restart if the last turn was <60s ago.
      LAST_TURN_TS=$(sqlite3 ~/.local/share/jarvis/turn_telemetry.db \
          "SELECT strftime('%s', ts_utc) FROM turns ORDER BY id DESC LIMIT 1" 2>/dev/null || echo "0")
      NOW=$(date +%s)
      AGE=$((NOW - LAST_TURN_TS))
      if [ "$AGE" -gt 60 ]; then
          systemctl --user restart jarvis-voice-agent.service
          echo "[$(date -u +%FT%TZ)] [automod-impl] voice-agent restarted"
      else
          echo "[$(date -u +%FT%TZ)] [automod-impl] restart deferred (session active ${AGE}s ago); new code loads on next natural restart"
      fi
  fi
} >>"$LOG" 2>&1
