[Unit]
Description=JARVIS voice client (native PortAudio mic/speaker bridge to LiveKit SFU)
# WebKit2GTK can't reliably do WebRTC PeerConnection, so the desktop
# UI offloads voice I/O to this native Python process. It joins the
# LiveKit room as identity=desktop-ulrich, publishes the mic, and
# plays the agent's audio track via PortAudio → ALSA/PipeWire.
# Voice-agent is a Wants (not Requires) — voice-client can run alone
# and will retry connecting, but they're operationally paired.
After=network-online.target livekit-server.service jarvis-voice-agent.service
Wants=network-online.target jarvis-voice-agent.service
Requires=livekit-server.service
# Page off-box if the mic/speaker bridge crash-loops into a failed state.
OnFailure=jarvis-alert@%n.service

[Service]
Type=notify
NotifyAccess=main
# Voice-client pings WATCHDOG=1 every 5 s from inside its asyncio loop
# (jarvis_voice_client.py:582). 30 s gives 6× ping margin before
# systemd kills + restarts on a wedge.
WatchdogSec=30s
WorkingDirectory=%h/Documents/Projects/jarvis/src/voice-agent
# Canonical source of LIVEKIT_URL / LIVEKIT_API_KEY / LIVEKIT_API_SECRET
# is the voice-agent's own .env. Repo-root .env (centralized 2026-05-15)
# is loaded after as an optional override, then per-tree overlays.
EnvironmentFile=%h/Documents/Projects/jarvis/src/voice-agent/.env
EnvironmentFile=-%h/Documents/Projects/jarvis/.env
EnvironmentFile=-%h/Documents/Projects/jarvis/src/cli/.env.local
# Local bridge bearer token (KEY=VALUE format, chmod 600). Optional
# (`-` prefix) so the unit doesn't fail before P0c is run.
EnvironmentFile=-%h/.jarvis/local-api-token.env
# ── Echo-cancellation mitigation (2026-05-20, see AEC cascade spec) ──
# JARVIS_NEURAL_AEC defaults to 1 in jarvis_voice_client.py, which makes
# _should_publish_during_speak() keep the mic HOT during TTS on speakers —
# on the assumption that the L3 neural residual canceller (DTLN) scrubs
# JARVIS's own echo. But L3 was never built (audio/dtln_aec.py +
# models/dtln_aec_128.onnx absent; only L1 PipeWire AEC3 runs), so the echo
# leaked into STT → hallucinated transcripts → JARVIS couldn't understand the
# user (live failure 2026-05-20 14:43–14:48). Forcing 0 restores the mic-drop-
# while-speaking safety net (spec §4.2 bottom-of-ladder). Cost: no barge-in
# during TTS on speakers until L3 ships. REMOVE this line when the robust gate
# fix / real L3 build lands. docs/superpowers/specs/2026-05-19-echo-cancellation-cascade-design.md
Environment=JARVIS_NEURAL_AEC=1
Environment=JARVIS_NEURAL_AEC_LATENCY_BUDGET_MS=15
# Use the voice-agent's venv directly so we don't need to source it
# in ExecStart — the voice-client lives in the same package layout
# and shares deps (livekit + sounddevice + sdnotify).
ExecStart=%h/Documents/Projects/jarvis/src/voice-agent/.venv/bin/python %h/Documents/Projects/jarvis/src/voice-agent/jarvis_voice_client.py
# Auto-recover from PortAudio glitches / SFU restart / LiveKit
# session drops. RestartSec=5 matches the voice-agent unit.
Restart=always
RestartSec=5
# Append to dedicated log so it doesn't intermix with voice-agent.log.
# Rotation handled by scripts/rotate-jarvis-logs.sh on a daily timer.
StandardOutput=append:%h/.local/share/jarvis/logs/voice-client.log
StandardError=append:%h/.local/share/jarvis/logs/voice-client.log

# ────────────────────────────────────────────────────────────────────
# Sandbox hardening — mirrors the voice-agent unit. Intentionally NOT
# set: NoNewPrivileges (would block sudo), ProtectHome (writes to
# ~/.local/share/jarvis), PrivateDevices (needs /dev/snd for PortAudio),
# ProtectSystem=strict, MemoryDenyWriteExecute (PortAudio uses W+X).
# ────────────────────────────────────────────────────────────────────
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
RestrictSUIDSGID=yes
RestrictNamespaces=yes
LockPersonality=yes
CapabilityBoundingSet=

[Install]
WantedBy=default.target
