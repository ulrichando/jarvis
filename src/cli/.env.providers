# .env.providers — Template for API keys
# Copy to .env.local and fill in your key for the provider you want to use.
# Never commit .env.local to git.

# ── Provider selection ─────────────────────────────────────────
# Set to: deepseek | groq | gemini | ollama | openai
# JARVIS_PROVIDER=deepseek

# ── API Keys (only the one you use is needed) ─────────────────
DEEPSEEK_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GOOGLE_API_KEY=AIza...
OPENAI_API_KEY=sk-...

# ── Model overrides (optional — sensible defaults are used) ───
# DEEPSEEK_MODEL=deepseek-chat
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4o

# ── Ollama (local) ────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Proxy port (default 4000) ─────────────────────────────────
# JARVIS_PROXY_PORT=4000
