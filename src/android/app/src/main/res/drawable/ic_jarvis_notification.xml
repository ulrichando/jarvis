<?xml version="1.0" encoding="utf-8"?>
<!-- JARVIS notification icon — monochrome arc reactor ring (white, used by NotificationCompat) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Outer ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M12,3 A9,9 0 1,1 11.99,3 Z" />

    <!-- Inner ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1"
        android:pathData="M12,7 A5,5 0 1,1 11.99,7 Z" />

    <!-- Center dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,10.5 A1.5,1.5 0 1,1 11.99,10.5 Z" />

</vector>
