<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ backup / data extraction rules.
    JARVIS excludes all sensitive data from cloud backup — API key and chat
    history stay on-device only.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database"   path="." />
        <exclude domain="file"       path="." />
        <exclude domain="external"   path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Allow device-to-device transfers for conversation history only
             (encrypted at rest via EncryptedSharedPreferences) -->
        <include domain="database" path="jarvis.db" />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file"       path="." />
    </device-transfer>
</data-extraction-rules>
