<?xml version="1.0" encoding="utf-8"?>
<!--
    JarvisDeviceAdmin policy declaration.
    Grants JARVIS DevicePolicyManager capabilities:
      - Lock screen / wipe (emergency use)
      - Password policy enforcement
      - Camera disable
    All destructive policies require explicit user confirmation in the UI.
-->
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-policies>
        <limit-password />
        <watch-login />
        <reset-password />
        <force-lock />
        <wipe-data />
        <expire-password />
        <encrypted-storage />
        <disable-camera />
        <disable-keyguard-features />
    </uses-policies>
</device-admin>
