# Caddy — plain-HTTP origin behind the host's cloudflared tunnel (Cloudflare
# terminates TLS at the edge; the tunnel delivers to localhost:80). This is the
# LIVE production shape on the VPS. The previous origin-TLS shape
# ({$JARVIS_DOMAIN} + Cloudflare Origin Certificate on :443) is in git history —
# restore it only if you front this with a proxied DNS record instead of a
# tunnel.
:80 {
	encode zstd gzip

	# searx.0wlan.com → SearXNG (JARVIS's keyless web_search backend).
	# Hostname-routed here; the public hostname is a cloudflared ingress rule
	# EXCLUDED from Cloudflare Access (same pattern as /install.sh + /releases).
	@searx host searx.0wlan.com
	reverse_proxy @searx searxng:8080

	# /code terminal websocket → the pty-server (8772). Rides the tunnel + app
	# auth; the socket additionally requires a per-session HS256 token in its
	# init frame (JARVIS_PTY_REQUIRE_AUTH=1 in compose).
	@pty path /pty /pty/*
	reverse_proxy @pty web:8772

	reverse_proxy web:3000

	# Baseline origin headers — Cloudflare WAF/Access are the primary edge layer.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
