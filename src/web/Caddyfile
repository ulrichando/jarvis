# Caddy — origin TLS + reverse proxy. Cloudflare sits IN FRONT of this
# (DNS proxied, mode Full (strict)). Set JARVIS_DOMAIN in .env.production.

{$JARVIS_DOMAIN:localhost} {
	# Cloudflare Origin Certificate (Cloudflare dash → SSL/TLS → Origin Server →
	# Create Certificate), dropped into the cert dir the compose caddy service
	# mounts (./certs by default → /etc/caddy/certs). For local/no-CF, comment
	# this line out — Caddy uses its internal CA instead (then set Cloudflare's
	# SSL mode to "Full", not "Full (strict)").
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key

	encode zstd gzip

	# /code terminal websocket → the pty-server (8772). Routed through Caddy so
	# it rides TLS + Cloudflare Access instead of being a raw exposed port. Set
	# NEXT_PUBLIC_PTY_URL=wss://$JARVIS_DOMAIN/pty at BUILD time so the browser
	# uses this path. The pty socket now requires a per-session HS256 token in
	# its init frame (minted by /api/workspace/[id]/pty-token, behind the app
	# auth; JARVIS_PTY_REQUIRE_AUTH=1 in compose) — so Access + app login + the
	# socket token are three independent layers, not one.
	@pty path /pty /pty/*
	handle @pty {
		reverse_proxy web:8772
	}

	# Hub Gateway (JARVIS Hub sub-project 1): JWT-gated multi-provider LLM proxy.
	# handle_path strips /hub ATOMICALLY so the proxy sees its native /v1/* (+
	# /config) — avoids the classic strip-then-rematch bug of a looser matcher.
	# Cloudflare Access EXCLUDES /hub (clients auth with the login JWT, not the
	# Access cookie). See docs/runbook/hub-gateway-deploy.md.
	handle_path /hub/* {
		reverse_proxy hub:4000
	}

	# Everything else → the Next app.
	handle {
		reverse_proxy web:3000
	}

	# Baseline origin headers — Cloudflare WAF/Access are the primary edge layer.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
