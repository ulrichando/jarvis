# JARVIS web — production env template. Copy to .env.production (gitignored)
# and fill in. For real prod, source these from a secrets manager instead of
# a file on disk (see docs/runbook/deploy-online.md).

# ── Identity / host (blocker #3) ────────────────────────────────────────────
JARVIS_DOMAIN=jarvis.example.com
JARVIS_WEB_ALLOWED_HOSTS=jarvis.example.com   # else every /api/* 403s
JARVIS_CANONICAL_HOST=jarvis.example.com
BETTER_AUTH_URL=https://jarvis.example.com
JARVIS_REQUIRE_LOCAL_AUTH=1
JARVIS_LOCAL_API_TOKEN=                        # openssl rand -hex 32
BETTER_AUTH_SECRET=                            # openssl rand -hex 32 (required — app errors on the default)
# Signs the per-session /code terminal (PTY) token AND the local-proxy token.
# Set it explicitly in prod so the value is stable across container recreates
# (the app otherwise lazy-creates it in ~/.jarvis/keys.env, which an ephemeral
# container loses on restart, silently rotating it).
JARVIS_PROXY_JWT_SECRET=                        # openssl rand -base64 32
NEXT_PUBLIC_PTY_URL=wss://jarvis.example.com/pty  # BUILD-TIME: /code terminal endpoint (via Caddy)

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=                             # openssl rand -base64 24 (rotated!)
DATABASE_URL=postgresql://jarvis:CHANGEME@postgres:5432/jarvis

# ── Sandbox (the hardened executor) ─────────────────────────────────────────
JARVIS_WORKSPACES_ROOT=/srv/jarvis/workspaces  # HOST path (DooD bind mounts)
JARVIS_SANDBOX_READONLY=1
# JARVIS_SANDBOX_NETWORK=none                   # uncomment for zero-egress sandboxes
# JARVIS_SANDBOX_RUNTIME=runsc                  # gVisor (install runsc on the host first)

# ── Provider keys (ROTATED — old ones are in git history) ───────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
KIMI_API_KEY=
