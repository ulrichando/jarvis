# JARVIS web frontend env. Anything prefixed NEXT_PUBLIC_ ships to the
# browser bundle; everything else is server-side only.
#
# Provider API keys mirrored from /home/ulrich/Documents/Projects/jarvis/.env.
# Next.js only loads .env files at the app root, so we copy them
# here. If you rotate a key upstream, update this file too.
#
# Anthropic / OpenAI / Google / Kimi keys are NOT set — those models
# in the picker will return a "missing API key" error if selected.
# Add the keys below when you have them and restart the dev server.

NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Voice client HTTP control plane — used by /chat/voice/[sessionId]
# composer to inject typed turns into a live voice session.
NEXT_PUBLIC_VOICE_CLIENT_URL=http://127.0.0.1:8767

DEEPSEEK_API_KEY=sk-168b2769b20448d893beb244b5f4eced
GROQ_API_KEY=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
# ANTHROPIC_API_KEY=...
# OPENAI_API_KEY=...
# GOOGLE_API_KEY=...
# KIMI_API_KEY=...

# Postgres for chat persistence (conversations, messages, etc.)
# Tables live in the 'web' schema — see schema.ts. The 'jarvis'
# DB itself is shared with the memory system (different schema).
DATABASE_URL=postgresql://jarvis:697968751ando@localhost:5432/jarvis
