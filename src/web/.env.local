# JARVIS web frontend env. Anything prefixed NEXT_PUBLIC_ ships to the
# browser bundle; everything else is server-side only.

# Convex backend URL. Self-hosted local instance on this laptop. Switch
# to a Tailscale / public URL later when you want the web UI to read
# from a Convex running on Proxmox or elsewhere.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
