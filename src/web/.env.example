# ─── LLM providers ────────────────────────────────────────────
# Fill in the ones you want to use. Empty = model hidden / errors at call time.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT-5, o3)
OPENAI_API_KEY=

# Google (Gemini) — key from https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq (free tier for Llama, Kimi K2, Qwen, etc)
GROQ_API_KEY=

# DeepSeek (V3, R1)
DEEPSEEK_API_KEY=

# Kimi / Moonshot (optional override of base URL)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# ─── Kimi K2.6 modes (web chat) ────────────────────────────────
# Off by default. When set to "1", kimi-k2-{instant,thinking,agent,swarm}
# model selections route through src/lib/ai/kimi/ instead of the legacy
# single-call path. Spec: docs/superpowers/specs/2026-05-05-kimi-k2-modes-web-design.md
KIMI_K2_MODES_ENABLED=0

# Per-day cost ceiling (USD) for the Swarm mode. Default $5.00.
# Counted by Redis key kimi:swarm:spend:YYYY-MM-DD with end-of-UTC-day expiry.
KIMI_SWARM_DAILY_BUDGET_USD=5.00

# Swarm budget tracker uses the JARVIS hub Redis (already used by other
# server modules). Falls back to local Redis at 127.0.0.1:6379 if unset.
# JARVIS_HUB_URL=redis://localhost:6379

# ─── Persistence (optional — in-memory chat works without it) ─
# Free Postgres: neon.tech or supabase.com
DATABASE_URL=

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3100
