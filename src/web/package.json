{
  "name": "web",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "overrides": {
    "shell-quote": "1.8.4",
    "form-data": "4.0.6"
  },
  "scripts": {
    "dev": "concurrently -n next,pty -c blue,magenta \"next dev -H 127.0.0.1\" \"node scripts/pty-server.mjs\"",
    "dev:next": "next dev -H 127.0.0.1",
    "dev:pty": "node scripts/pty-server.mjs",
    "build:image": "docker build -t jarvis-workbench:latest scripts/workbench-image",
    "build": "next build",
    "db:migrate": "drizzle-kit migrate",
    "start": "concurrently -n next,pty -c blue,magenta \"next start -H 127.0.0.1\" \"node scripts/pty-server.mjs\"",
    "start:container": "concurrently -k -n next,pty -c blue,magenta \"next start -H 0.0.0.0\" \"node scripts/pty-server.mjs\"",
    "lint": "eslint",
    "postinstall": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
