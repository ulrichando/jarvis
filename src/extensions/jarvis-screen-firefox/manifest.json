{
  "manifest_version": 2,
  "name": "JARVIS",
  "version": "2.0.0",
  "description": "JARVIS — native DOM-aware AI side panel with multi-tab context",
  "browser_specific_settings": {
    "gecko": {
      "id": "jarvis@0wlan.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "browser_action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Open JARVIS"
  },
  "sidebar_action": {
    "default_panel": "side_panel.html",
    "default_title": "JARVIS",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "open_at_install": false
  },
  "commands": {
    "capture-screen": {
      "suggested_key": {
        "default": "Ctrl+Shift+J"
      },
      "description": "Open JARVIS sidebar"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
