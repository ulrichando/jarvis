{
  "manifest_version": 3,
  "name": "Jarvis in Chrome",
  "version": "3.0.0",
  "description": "Lets Jarvis act on web pages. The service worker holds a WebSocket to the local Jarvis bridge (127.0.0.1:8765); Jarvis sends deterministic commands (navigate, click, type, read) that run in the active tab.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "webNavigation",
    "cookies",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["safety.js", "actions.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": { "default_path": "side_panel.html" },
  "action": { "default_title": "Jarvis in Chrome" }
}
