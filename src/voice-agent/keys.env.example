# JARVIS — provider API keys template (~/.jarvis/keys.env)
# =========================================================
#
# Copy this file to `~/.jarvis/keys.env` and fill in the keys you have.
# The Tray UI also writes/clears entries here as you toggle providers.
#
# Loaded at startup by `_load_user_keys_env()` in `jarvis_agent.py`;
# values here OVERRIDE values in `src/voice-agent/.env` on collision.
# Keep secrets OUT of the repo — this template is intentionally empty;
# real `keys.env` lives at $HOME/.jarvis/keys.env (never committed).
#
# Only set the keys for providers you actually use. JARVIS gates each
# tool/provider via a `check_fn` — unset keys silently skip that surface.
# A minimum-viable JARVIS needs ONE LLM provider key (Groq recommended).


# =============================================================================
# LLM PROVIDERS — at least one required
# =============================================================================

# Groq — fast inference, default supervisor provider for BANTER + cheap routes
# https://console.groq.com/keys
# GROQ_API_KEY=

# Anthropic — Claude Sonnet/Haiku/Opus; current TASK + REASONING default
# https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# DeepSeek — strong fallback for all routes
# https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=

# OpenAI — GPT family + image generation
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Google Gemini — same backend as GOOGLE_API_KEY
# https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# OpenRouter — multi-model gateway (one key, many models)
# https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# xAI / Grok
# https://console.x.ai
# XAI_API_KEY=
# XAI_BASE_URL=

# Moonshot Kimi (K2.6) — voice supervisor BROKEN, gate JARVIS_KIMI_VOICE_EXPERIMENTAL=1
# https://platform.moonshot.ai
# KIMI_API_KEY=

# OpenViking
# OPENVIKING_API_KEY=

# Codex (OpenAI Codex-style local agent)
# CODEX_ACCESS_TOKEN=
# CODEX_AUTH_FILE=                  # path to Codex auth JSON


# =============================================================================
# SPEECH-TO-TEXT
# =============================================================================

# Deepgram Nova-3 — primary streaming STT (needed for STT-confirmed barge-in)
# Without it: Groq Whisper Turbo fallback (non-streaming; barge-in degraded).
# https://console.deepgram.com
# DEEPGRAM_API_KEY=


# =============================================================================
# TEXT-TO-SPEECH (alternative backends; Groq Orpheus uses GROQ_API_KEY above)
# =============================================================================

# ElevenLabs (premium TTS)
# https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=


# =============================================================================
# WEB / SEARCH providers (web_search, web_fetch, web_crawl)
# =============================================================================

# Brave Search — default web_search backend
# https://api.search.brave.com/app/keys
# BRAVE_SEARCH_API_KEY=

# Exa — alternative search
# https://exa.ai
# EXA_API_KEY=

# Tavily — alternative search
# https://tavily.com
# TAVILY_API_KEY=
# TAVILY_BASE_URL=                  # override

# Firecrawl — web_fetch / web_crawl backend
# https://firecrawl.dev
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=                # self-hosted override
# FIRECRAWL_BROWSER_TTL=            # seconds

# SearxNG — self-hosted privacy-respecting meta-search
# SEARXNG_URL=

# Parallel
# PARALLEL_API_KEY=
# PARALLEL_SEARCH_MODE=


# =============================================================================
# MEMORY backends — set JARVIS_MEMORY_PROVIDER in .env to pick one,
# then provide that one's key here.
# =============================================================================
# Options for JARVIS_MEMORY_PROVIDER:
#   honcho | mem0 | supermemory | byterover | holographic | hindsight | retaindb

# Honcho — dialectic memory (https://honcho.dev)
# HONCHO_API_KEY=
# Mem0  (https://mem0.ai)
# MEM0_API_KEY=
# Supermemory (https://supermemory.ai)
# SUPERMEMORY_API_KEY=
# Byterover
# BYTEROVER_API_KEY=
# Holographic
# HOLOGRAPHIC_API_KEY=
# Hindsight
# HINDSIGHT_API_KEY=
# RetainDB
# RETAINDB_API_KEY=


# =============================================================================
# BROWSER backends (browser_task)
# =============================================================================
# JARVIS default = local headless `browser_use` in an isolated venv.
# Browserbase = cloud-Chrome alternative driven over CDP.
# https://browserbase.com

# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# BROWSERBASE_KEEP_ALIVE=            # 1 = keep session warm
# BROWSERBASE_PROXIES=               # JSON proxy config
# BROWSERBASE_ADVANCED_STEALTH=      # 1 = stealth mode
# BROWSERBASE_SESSION_TIMEOUT=       # seconds


# =============================================================================
# IMAGE / VIDEO generation
# =============================================================================

# fal.ai — video + image
# https://fal.ai/dashboard/keys
# FAL_KEY=
# FAL_VIDEO_MODEL=                  # model id override

# OpenAI image / xAI image — keys already above; model selection here
# OPENAI_IMAGE_MODEL=
# XAI_IMAGE_MODEL=
# XAI_IMAGE_RESOLUTION=             # e.g. 1024x1024


# =============================================================================
# X (Twitter) search via xAI — uses XAI_API_KEY above
# =============================================================================

# XAI_X_SEARCH_MODEL=
# XAI_X_SEARCH_RETRIES=
# XAI_X_SEARCH_TIMEOUT_SECONDS=


# =============================================================================
# SPOTIFY (spotify_* tools)
# =============================================================================
# Register an app at https://developer.spotify.com/dashboard

# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_ACCESS_TOKEN=             # OAuth token (Tray UI manages this)
# SPOTIFY_AUTH_FILE=                # path to cached token JSON


# =============================================================================
# HOME ASSISTANT (ha_* tools)
# =============================================================================
# Long-lived access token: HA UI → Profile → Security → Long-Lived Access Tokens

# HASS_URL=                         # e.g. http://homeassistant.local:8123
# HASS_TOKEN=


# =============================================================================
# DISCORD
# =============================================================================
# Bot token: https://discord.com/developers/applications

# DISCORD_BOT_TOKEN=


# =============================================================================
# VULNERABILITY SCANNING (vuln_check tool)
# =============================================================================

# OSV_ENDPOINT=                     # override default https://api.osv.dev


# =============================================================================
# LOCAL API auth (bridge ↔ browser extension)
# =============================================================================
# Used by the bridge + extension when JARVIS_REQUIRE_LOCAL_AUTH=1.

# API_BASE_URL=                     # bridge URL (default http://127.0.0.1:8765)
# API_TOKEN=                        # shared secret
