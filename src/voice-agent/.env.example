# JARVIS voice-agent — environment template
# Copy to .env (gitignored) and fill in the values that apply.
#
# This file lists ONLY the bootstrap vars needed by the systemd unit
# and the LiveKit client. API keys (Groq, DeepSeek, OpenAI, Anthropic,
# Kimi, Google) live in ~/.jarvis/keys.env so they survive across
# repo checkouts and aren't accidentally committed. _load_user_keys_env()
# in jarvis_agent.py reads keys.env at startup; values there override
# repo .env values on collision.
#
# Optional JARVIS_* tuning knobs are documented in their respective
# modules — grep `os.environ.get("JARVIS_` for the full surface area.

# ── LiveKit SFU (required) ────────────────────────────────────────────
# URL of the local livekit-server. The keypair must match livekit.yaml
# (the agent uses these to authenticate its SFU connection). Rotate
# both at once if you rotate one.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Display environment (required for desktop tools) ──────────────────
# Set so xdotool/scrot can find the active X server when the agent
# runs under a systemd user unit. JARVIS_USER_UID is read by some
# subprocess shims to drop privileges back to the user.
DISPLAY=:0
XAUTHORITY=/home/ulrich/.Xauthority

# ── Edge TTS fallback voice (optional, has default) ───────────────────
# Microsoft Edge neural-TTS voice used as the FallbackAdapter safety
# net when Groq Orpheus has an outage. Voice IDs:
#   https://learn.microsoft.com/azure/cognitive-services/speech-service/language-support
JARVIS_EDGE_VOICE=en-US-ChristopherNeural

# ── Slow-path classifier (optional, JARVIS_GRAPH_DISABLED=1 reverts) ──
# Which LLM the LangGraph turn-router uses for BANTER/TASK/REASONING/
# EMOTIONAL classification. Default Groq llama-3.1-8b-instant.
# JARVIS_ROUTER_PROVIDER=groq
# JARVIS_ROUTER_MODEL=llama-3.1-8b-instant

# ── Subagent enable flags (optional) ──────────────────────────────────
# All seven gated off by default 2026-05-08 — re-enable individually
# as supervisor `delegate` routing is hardened. See CLAUDE.md
# "Subagent registry" section.
# JARVIS_SUBAGENT_SUMMARIZE=1
# JARVIS_SUBAGENT_WEATHER=1
# JARVIS_SUBAGENT_RESEARCHER=1
# JARVIS_SUBAGENT_VALIDATOR=1
# JARVIS_SUBAGENT_CODE_REVIEWER=1
# JARVIS_SUBAGENT_MEMORY_RECALL=1
# JARVIS_SUBAGENT_GITHUB=1
