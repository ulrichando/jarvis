{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JARVIS",
  "version": "0.1.0",
  "identifier": "com.jarvis.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png"]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "J.A.R.V.I.S.",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "width": 1920,
        "height": 1080,
        "x": 0,
        "y": 0,
        "visible": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
