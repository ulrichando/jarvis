{
  "manifest_version": 3,
  "name": "JARVIS Screen Vision",
  "version": "2.0.0",
  "description": "JARVIS — native DOM-aware AI side panel with multi-tab context",
  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8765/*",
    "https://jarvis.local/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "commands": {
    "capture-screen": {
      "suggested_key": {
        "default": "Ctrl+Shift+J"
      },
      "description": "Capture screen and send to JARVIS"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
