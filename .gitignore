# Virtual environment — anchor to repo root only so we don't shadow
# src/cli/src/commands/env/ (the bug fixed by old-master PR #4,
# re-applied here after the feat-v3 force-push lost it).
/.venv/
/venv/
/env/

# Playwright MCP scratch (screenshots, console logs, page dumps)
.playwright-mcp/

# Build artifacts
target/
*.egg-info/
jarvis.egg-info/
__pycache__/
*.pyc
*.pyo
dist/
build/

# Node modules
node_modules/

# Rust/Tauri build cache
src/voice-agent/desktop-tauri/src-tauri/target/
# Phase 2 bundle staging (~3.7 GB: staged venv + voice-agent source); build artifact, never commit
src/voice-agent/desktop-tauri/src-tauri/bundle-assets/

# Runtime data
*.db
*.db-journal
*.snap
*.bak
*.log
*.msgpack
data/
screenshots/

# Sandbox
.sandbox-home/
.sandbox-tmp/

# OS/IDE
.DS_Store
.idea/
.vscode/
*.swp

# Packer/VM outputs (JARVIS OS)
src/os/packer/output*/
src/os/*.iso
src/os/*.img
src/os/*.vmdk
src/os/*.ova

# Frontend dist (built at runtime)
src/voice-agent/desktop-tauri/dist/

# Backup files
*.py.bak

# Export dumps
jarvis-export-*.json

# Reference source (Claude Code src — not part of JARVIS)
resource-info/

# Android client build artifacts (Gradle, APKs, SDK path)
src/android/build/
src/android/app/build/
src/android/app/.cxx/
src/android/.gradle/
src/android/local.properties
*.apk
*.aab

# OpenCL ICD loader stubs — built on demand via
# src/android/scripts/build-opencl-stub.sh, one per ABI.
src/android/app/src/main/cpp/opencl-stub/*/libOpenCL.so
src/android/app/src/main/cpp/third_party/*/build/

# Browser-extension packaged artifacts + signing keys
*.crx
*.xpi
*.pem

# LLM documentation and claude-code reference
llm/
jarvis-cli/
.superpowers/
.worktrees/
.gstack/
.pytest_cache/
.remember/

# The generic data/ and llm/ rules above (intended for runtime data dirs and
# top-level LLM docs) ALSO match SOURCE directories inside the Android app —
# .../com/jarvis/android/data/ and .../system/llm/ — silently leaving large
# parts of the app unversioned. Re-include the app's own Kotlin source (main +
# test); placed after both rules so the negation wins. The vendored
# cpp/llama.cpp tree keeps its own ignores and is untouched by this.
!src/android/app/src/main/java/com/jarvis/android/**/
!src/android/app/src/main/java/com/jarvis/android/**
!src/android/app/src/test/java/com/jarvis/android/**/
!src/android/app/src/test/java/com/jarvis/android/**

# Claude Code — personal overrides stay local
CLAUDE.local.md
.claude/CLAUDE.local.md
.claude/settings.local.json
**/*.local.md

# Secrets — every tracked .env was leaking credentials in commit
# history. Untracking on 2026-05-01. Example files stay tracked.
.env
.env.local
.env.providers
.env.production
.env.tmp
# Rotation backups (.env.local.bak-<ts>, .env.bak.<date>, …) — these slipped
# past the bare ".env.local" rule and were committable, re-leaking old secrets.
.env*.bak*
*.env.bak*
!.env.example
!**/.env.example

# Vendored third-party agent checkout (NousResearch/hermes-agent), cloned 2026-05-20.
# Source-only reference; not part of any JARVIS subtree.
hermes/

# Vendored Cookbook (Odysseus carve-out + its clone + the deps venv), 2026-06-19.
# vendor/odysseus = upstream clone (source), vendor/cookbook = the minimal
# carve-out the JARVIS Cookbook sidecar runs. AGPL-3.0; never committed into
# JARVIS — reproducible from the clone + the file list in vendor/cookbook/VENDOR_NOTES.md.
vendor/

# livekit-server binary — fetched at install time via ensure_livekit_binary() in install.sh.
# Pinned SHA-256 lives in setup/livekit-server.bin.sha256.
/src/voice-agent/livekit-server.bin
# Windows equivalent — fetched at install time (livekit_<ver>_windows_amd64.zip).
# Both are platform-specific ~16-50 MB binaries; never commit them.
/src/voice-agent/livekit-server.exe

# Native build outputs (defense-in-depth; .cxx covered in Android block above)
*.o
*.a
*.ninja_deps
*.ninja_log

# Stray runtime error logs
*.err.log

# Belt-and-suspenders: never re-commit a docs-stashed credential note
**/API keys
**/*api*key*.txt

# The legacy cwd-relative settings.json could catch a committed API key (the
# 2026-06 leak shape). Ignore the settings file at ANY depth — but NOT the rest
# of .jarvis/ (the repo-root .jarvis/agents/ + setup.sh are legit tracked
# source). Real settings live in ~/.jarvis/.
**/.jarvis/settings.json
